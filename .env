# Server Configuration
SERVER_NAME=bazhuayu-mcp-server
SERVER_VERSION=1.0.0
PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:8080
NODE_ENV=local

# API Configuration
CLIENTAPI_BASE_URL=https://pre-v2-clientapi.bazhuayu.com
WEBAPI_BASE_URL=https://pre-webapi.bazhuayu.com
OIDC_ISSUER=https://pre-identity.bazhuayu.com
OFFICIAL_SITE_URL=https://pre.bazhuayu.com
OFFICIAL_UPGRADE_URL=https://pre.bazhuayu.com/pricing
OFFICIAL_DOWNLOAD_URL=https://pre.bazhuayu.com/download

# HTTP Client Configuration
HTTP_TIMEOUT=30000
HTTP_RETRIES=3
HTTP_RETRY_DELAY=1000
HTTP_MAX_REDIRECTS=5
HTTP_USER_AGENT=bazhuayu-MCP-Server/1.0
HTTP_ACCEPT_LANGUAGE=en-US

# Security Configuration
ALLOWED_ORIGINS=*
TRUST_PROXY=true

# Logging Configuration
LOG_LEVEL=debug
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=false
LOG_FILE_PATH=./logs/server.log
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=5
LOG_STRUCTURED=true

# Redis Configuration (for distributed session)
REDIS_ENABLED=true
REDIS_HOST=10.4.5.200
REDIS_PORT=6379
REDIS_PASSWORD=tBXrKiK24MvM8FzVNUA2
REDIS_DB=10
REDIS_KEY_PREFIX=mcp:
REDIS_TLS=false
REDIS_SESSION_TTL=2592000
