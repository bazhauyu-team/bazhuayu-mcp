{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "copy-env-local",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "if exist \"${workspaceFolder}\\.env.local\" copy \"${workspaceFolder}\\.env.local\" \"${workspaceFolder}\\.env\""
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build-and-copy-env",
      "type": "shell",
      "dependsOrder": "sequence",
      "dependsOn": ["npm: build", "copy-env-local"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}