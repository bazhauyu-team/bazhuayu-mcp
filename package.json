{
  "name": "bazhuayu-mcp-server",
  "version": "1.0.0",
  "description": "AI-native bazhuayu MCP server with a 3-tool workflow",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:web && npm run build:server",
    "build:server": "tsc",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "check:unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke:live": "node scripts/live-smoke.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.24.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "axios": "^1.12.0",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^30.1.3",
    "nock": "^14.0.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  }
}
